<Window x:Class="WpfMapsUiTest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfMapsUiTest"
        xmlns:wpf="clr-namespace:Mapsui.UI.Wpf;assembly=Mapsui.UI.Wpf"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800"
        d:DataContext="{d:DesignInstance local:MainWindowViewModel}"
        DataContextChanged="MainWindow_OnDataContextChanged">
    <Grid >
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Border BorderBrush="Black" BorderThickness="1">
            <wpf:MapControl VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                                 x:Name="MapControl" />
        </Border>


        <DockPanel Grid.Column="0" Grid.Row="0" HorizontalAlignment="Left" VerticalAlignment="Center">
            <StackPanel Orientation="Vertical" Background="Gray">
                <Label Content="TextBox1"/>
                <TextBox Width="100" ToolTip="some text"/>
                <Label Content="ComboBox1"/>
                <ComboBox Width="100" ItemsSource="{Binding Collection1}" ToolTip="some text"/>
            </StackPanel>
        </DockPanel>

        <StackPanel Grid.Column="1" Grid.Row="0" Orientation="Vertical" Margin="10">
            <TextBox Text="{Binding ObjectsCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            <Label Content="TextBox2"/>
            <TextBox Width="150" ToolTip="some text" Margin="5"></TextBox>
            <Label Content="ComboBox2"/>
            <ComboBox Width="150" ItemsSource="{Binding Collection2}" 
                      ToolTip="some text" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>
